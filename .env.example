# Copy this file to .env and fill in values for local development.
# .env is gitignored; .env.example is the committed template.
#
# Loaded by `pnpm dev` via Node's --env-file-if-exists flag.

# Path to the principal config file. Relative to the server's CWD
# (apps/server/ when running via `turbo dev`). Create one by copying
# apps/server/config.example.json or by running c17-server interactively
# to trigger the first-run wizard.
C17_CONFIG_PATH=./config.dev.json

# Token for the operator CLI (c17 push, c17 agents, c17 connect).
# Must match one of the tokens in the config file above.
C17_TOKEN=c17_dev_operator_secret

# Optional — broker listen address and port.
C17_HOST=127.0.0.1
C17_PORT=8717

# Optional — SQLite event log path. Use :memory: for ephemeral runs.
C17_DB_PATH=/tmp/c17-dev.db
