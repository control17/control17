# Turborepo
.turbo
# Build artifacts
dist
*.tsbuildinfo

# Editors / OS
.vscode/
.idea/
.DS_Store

# Local dev config (tokens, absolute paths — see .mcp.example.json)
.mcp.json

# Local dev server config (contains plaintext tokens — see apps/server/config.example.json)
config.dev.json
apps/server/config.dev.json
# Wizard-generated dev config at the repo root (what `pnpm setup` writes)
/control17.json
# Self-signed certs generated alongside the root-level config
/certs/

# Web build output. `packages/web` is configured to write its `vite build`
# straight into the server's static root so Hono's serveStatic picks it up
# with no copy step. Everything under here is generated — hashed assets,
# the rewritten index.html, the PWA manifest + service worker, copied
# favicon/logo/icons. Source for all of it lives in packages/web/{src,public,index.html}.
apps/server/public/

# vite-plugin-pwa dev-mode output (disabled in vite.config.ts but the
# plugin will still drop a dev-dist if anyone flips devOptions.enabled).
dev-dist/

# Local vite cache outside node_modules (safety net — usually it's in
# node_modules/.vite which is already covered).
**/.vite/

# Stray local databases
*.db
*.db-journal
*.db-wal
*.db-shm
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# tsup bundled config cache (esbuild rewrites the config with a random
# suffix during watch-mode startup; gets stranded on crashes)
tsup.config.bundled_*.mjs
