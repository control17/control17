{
  "name": "@control17/server",
  "version": "0.0.0",
  "description": "Node HTTP broker for control17 — self-hostable agent control plane (Hono + SQLite).",
  "license": "Apache-2.0",
  "author": "Andrew Przybilla <andrewprzybilla@gmail.com>",
  "homepage": "https://github.com/control17/control17#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/control17/control17.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/control17/control17/issues"
  },
  "keywords": [
    "control17",
    "c17",
    "mcp",
    "agent",
    "broker",
    "server",
    "self-hosted",
    "hono",
    "sqlite"
  ],
  "type": "module",
  "main": "./dist/run.js",
  "types": "./dist/run.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js"
    }
  },
  "bin": {
    "c17-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'node --env-file-if-exists=../../.env ./dist/index.js'",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@control17/core": "workspace:*",
    "@control17/sdk": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@control17/link": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
