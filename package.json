{
  "name": "control17",
  "version": "0.3.1",
  "private": true,
  "description": "Command & control plane for AI agent operations. OSS monorepo.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@control17/server --filter=@control17/web",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "bump": "node scripts/bump-version.mjs",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks",
    "wizard": "node packages/cli/dist/index.js setup",
    "c17": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
