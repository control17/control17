{
  "name": "@control17/sdk",
  "version": "0.2.0",
  "description": "Contract and TypeScript SDK for control17 — MCP-based agent control plane.",
  "license": "Apache-2.0",
  "author": "Andrew Przybilla <andrewprzybilla@gmail.com>",
  "homepage": "https://github.com/control17/control17#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/control17/control17.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/control17/control17/issues"
  },
  "keywords": [
    "control17",
    "c17",
    "mcp",
    "model-context-protocol",
    "agent",
    "agent-coordination",
    "agent-control-plane",
    "claude-code",
    "claude-channel",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
