{
  "name": "@control17/c17",
  "version": "0.3.1",
  "description": "Meta-package for control17 — installs the complete agent control plane (cli, server, sdk, core) in one command.",
  "license": "Apache-2.0",
  "author": "Andrew Przybilla <andrewprzybilla@gmail.com>",
  "homepage": "https://github.com/control17/control17#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/control17/control17.git",
    "directory": "packages/c17"
  },
  "bugs": {
    "url": "https://github.com/control17/control17/issues"
  },
  "keywords": [
    "control17",
    "c17",
    "mcp",
    "agent",
    "agent-control-plane",
    "meta-package",
    "bundle"
  ],
  "type": "module",
  "bin": {
    "c17": "./bin/c17.mjs",
    "c17-server": "./bin/c17-server.mjs"
  },
  "files": [
    "bin"
  ],
  "dependencies": {
    "@control17/cli": "workspace:*",
    "@control17/core": "workspace:*",
    "@control17/sdk": "workspace:*",
    "@control17/server": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
