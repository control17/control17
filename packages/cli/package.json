{
  "name": "@control17/cli",
  "version": "0.3.1",
  "description": "Operator CLI for control17 — push events to running agents, list agents, run a local broker.",
  "license": "Apache-2.0",
  "author": "Andrew Przybilla <andrewprzybilla@gmail.com>",
  "homepage": "https://github.com/control17/control17#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/control17/control17.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/control17/control17/issues"
  },
  "keywords": [
    "control17",
    "c17",
    "cli",
    "mcp",
    "agent",
    "agent-control-plane",
    "operator"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "c17": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@control17/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-forge": "^1.3.1"
  },
  "peerDependencies": {
    "@control17/server": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@control17/server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@control17/server": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "selfsigned": "^5.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
